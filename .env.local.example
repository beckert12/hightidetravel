# Copy this file to `.env.local` for local development.
# The AI Trip Planner (/points-tool) calls the Claude API server-side.

# Your Anthropic API key — get one at https://console.anthropic.com
# In production, set this in Cloudflare Pages → Settings → Environment variables
# (encrypted) for BOTH Production and Preview — do NOT commit your real key.
ANTHROPIC_API_KEY=sk-ant-...
